{
  "manifest_version": 3,
  "name": "CMS AI Helper",
  "version": "1.0.0",
  "description": "FASTFIVE CMS 사이트 AI 도우미. 현재 화면 컨텍스트를 기반으로 사용법을 안내합니다.",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "tabs",
    "scripting"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://admin.fastfive.co.kr/*",
        "https://admin.dev.fastfive.co.kr/*",
        "https://cms-dev.slowfive.com/*",
        "https://cms-staging.slowfive.com/*",
        "https://cms.slowfive.com/*",
        "http://localhost/*"
      ],
      "js": ["guide-data.js", "content.js", "guide.js"],
      "css": ["guide.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "FASTFIVE CMS Helper"
  },
  "host_permissions": [
    "https://admin.fastfive.co.kr/*",
    "https://admin.dev.fastfive.co.kr/*",
    "https://cms-dev.slowfive.com/*",
    "https://cms-staging.slowfive.com/*",
    "https://cms.slowfive.com/*",
    "http://localhost/*",
    "https://*.ngrok-free.dev/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["knowledge.md"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
